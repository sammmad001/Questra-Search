# Questra-Search 环境配置模板
# 复制为 .env 并填入真实值: cp .env.example .env

# Questra-Search 上游 API (MiroThinker)
MIROMIND_API_BASE=https://api.miromind.ai/v1
MIROMIND_API_KEY=YOUR_API_KEY_HERE
DEFAULT_MODEL=mirothinker-1-7-deepresearch

# 服务配置
PORT=8900
REQUEST_TIMEOUT=300
BASE_PATH=/miro

# JWT 认证（部署时自动生成，或手动设置 32 字节随机密钥）
JWT_SECRET=CHANGE_ME_TO_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168

# Cookie 安全（HTTPS 后改为 true）
COOKIE_SECURE=false

# 域名配置（用于 Cloudflare CDN 入口）
# DOMAINS=mmaoresearch.com,www.mmaoresearch.com

# SQLite 数据库
DATABASE_PATH=data/questra_search.db

# ── 个人知识库集成 ──
# KB_API_BASE: 知识库 API 地址（需根据实际部署调整）
KB_API_BASE=http://localhost:8080
# KB_API_TOKEN: 知识库 API 认证令牌（需与 KB 侧 .env 中 KNOWLEDGE_API_TOKEN 一致）
KB_API_TOKEN=YOUR_KB_API_TOKEN_HERE
# KB_AUTO_INGEST: 是否自动导入聊天内容到知识库（true/false）
KB_AUTO_INGEST=true

# ── Prompts 框架 ──
# 是否启用 Prompts 框架（false 时回退到 SEARCH_INSTRUCTION）
PROMPTS_ENABLED=true
# 模板文件目录（相对于 app/services/prompts/）
PROMPTS_TEMPLATES_DIR=templates
# 分类置信度阈值（低于此值使用 general 模板，范围 0.0-1.0）
PROMPTS_CLASSIFICATION_THRESHOLD=0.3
# 每个模板的 system prompt 最大 token 预算
PROMPTS_MAX_SYSTEM_TOKENS=500
# 是否输出详细分类日志
PROMPTS_VERBOSE_LOG=false
